{
    "name": "cpfhub/cpfhub-php",
    "description": "Official PHP SDK for CPFHub.io — Brazilian CPF lookup API. Get name, gender and date of birth from any CPF in ~300ms.",
    "keywords": [
        "cpf",
        "cpf-api",
        "cpf-lookup",
        "cpf-validation",
        "cpf-consulta",
        "cpfhub",
        "brasil",
        "brazil",
        "receita-federal",
        "sdk",
        "api-client",
        "fintech",
        "kyc",
        "identity-verification",
        "onboarding",
        "lgpd",
        "laravel",
        "symfony"
    ],
    "homepage": "https://cpfhub.io",
    "license": "MIT",
    "authors": [
        {
            "name": "CPFHub.io",
            "email": "contato@cpfhub.io",
            "homepage": "https://cpfhub.io",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CPFHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CPFHub\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/cpfhub/cpfhub-php/issues",
        "source": "https://github.com/cpfhub/cpfhub-php",
        "docs": "https://cpfhub.io/documentacao"
    },
    "extra": {
        "laravel": {
            "providers": [
                "CPFHub\\Laravel\\CPFHubServiceProvider"
            ],
            "aliases": {
                "CPFHub": "CPFHub\\Laravel\\Facades\\CPFHub"
            }
        }
    }
}
